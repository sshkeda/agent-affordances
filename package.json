    "typecheck": "tsc --noEmit",
    "check": "bun run test && bun run typecheck",
    "prepack": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
