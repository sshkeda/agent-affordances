  "repository": {
    "type": "git",
    "url": "git+https://github.com/sshkeda/agent-affordances.git"
  },
  "bugs": {
    "url": "https://github.com/sshkeda/agent-affordances/issues"
  },
  "keywords": [
    "agent",
